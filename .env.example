# =============================================================================
# MCP Explorer — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# API (Garrard.Mcp.Explorer.Api)
# ---------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
AppMetadata__Version=0.5.0

# LLM Service defaults (can be overridden per model in the UI)
LlmService__OpenAiBaseUrl=https://api.openai.com/v1
LlmService__AzureApiVersion=2024-02-15-preview
LlmService__MaxRetryAttempts=3
LlmService__TimeoutSeconds=30

# Tool invocation timeout and retry (MCP connections can drop transiently)
ToolInvoke__TimeoutSeconds=300
ToolInvoke__MaxRetryAttempts=2

# Elicitation timeout (0 = wait indefinitely)
Elicitation__TimeoutSeconds=0

# ---------------------------------------------------------------------------
# Gateway (Garrard.Mcp.Explorer.Gateway) — docker-compose only
# In single-container mode the gateway talks to localhost:5000 directly.
# ---------------------------------------------------------------------------
ASPNETCORE_GATEWAY_URLS=http://+:8080

# Override YARP cluster destination for docker-compose (points to api service)
ReverseProxy__Clusters__api-cluster__Destinations__api__Address=http://api:5000/

# ---------------------------------------------------------------------------
# Preferences storage
# Set MCP_DATA_PATH to your existing McpExplorer settings directory to reuse
# connections from the original app (or any previous installation).
#
# macOS default:  /Users/<you>/Library/Application Support/McpExplorer
# Linux default:  /home/<you>/.local/share/McpExplorer
# Windows default: C:\Users\<you>\AppData\Local\McpExplorer
#
# Example (macOS):
#   MCP_DATA_PATH=/Users/kitcheng/Library/Application Support/McpExplorer
# ---------------------------------------------------------------------------
MCP_DATA_PATH=
PREFERENCES__StoragePath=


# Base URL the browser uses to reach the API (empty = same origin via gateway)
VITE_API_BASE_URL=

# App version shown in the UI
VITE_APP_VERSION=0.5.0
