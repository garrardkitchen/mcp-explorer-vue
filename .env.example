# =============================================================================
# MCP Explorer — Environment Variables
# Copy to .env and fill in your values.
#
# docker run  →  pass individual vars with -e, e.g. -e MCP_CLIENT_NAME=myapp
# docker compose →  copy this file to .env; compose reads it automatically
# =============================================================================

# ---------------------------------------------------------------------------
# ASPNET CORE — API container
# ---------------------------------------------------------------------------

# Runtime environment. Controls logging verbosity and error detail.
# Values: Development | Staging | Production  (default: Production)
ASPNETCORE_ENVIRONMENT=Production

# The URL(s) the API listens on inside the container.
# Do not change this unless you also change the internal port mapping.
ASPNETCORE_URLS=http://+:5000

# ---------------------------------------------------------------------------
# APP METADATA
# ---------------------------------------------------------------------------

# Version string returned by GET /api/v1/info and shown in the UI footer.
AppMetadata__Version=0.5.0

# ---------------------------------------------------------------------------
# MCP CLIENT
# ---------------------------------------------------------------------------

# Override the client name sent to MCP servers during the protocol handshake
# and included in the User-Agent header as "mcp-explorer:<version>/<hostname>".
# Defaults to "mcp-explorer" when empty or not set.
MCP_CLIENT_NAME=

# ---------------------------------------------------------------------------
# PREFERENCES / STORAGE
# ---------------------------------------------------------------------------

# Host directory that holds settings.json (connections, workflows, models, etc.).
# Mount this as a volume so data persists across container restarts.
#
# Set this to your existing McpExplorer data directory to reuse saved connections:
#   macOS:   /Users/<you>/Library/Application Support/McpExplorer
#   Linux:   /home/<you>/.local/share/McpExplorer
#   Windows: C:\Users\<you>\AppData\Local\McpExplorer
#
# When empty, docker-compose creates an anonymous named volume called mcp-data.
MCP_DATA_PATH=

# Absolute path to settings.json *inside* the container.
# Defaults to /data/settings.json when empty (matches the volume mount in
# docker-compose.yml). Only change this if you customise the volume target.
PREFERENCES__StoragePath=

# ---------------------------------------------------------------------------
# LLM SERVICE — defaults for all AI model integrations
# These can be overridden per-model in the AI Models UI.
# ---------------------------------------------------------------------------

# Base URL for OpenAI-compatible APIs (OpenAI, Azure OpenAI, local proxies).
LlmService__OpenAiBaseUrl=https://api.openai.com/v1

# Azure OpenAI REST API version used in the ?api-version= query parameter.
LlmService__AzureApiVersion=2024-02-15-preview

# Maximum number of retry attempts for a failed LLM request.
LlmService__MaxRetryAttempts=3

# Seconds to wait for an LLM response before timing out.
LlmService__TimeoutSeconds=30

# ---------------------------------------------------------------------------
# TOOL INVOCATION
# ---------------------------------------------------------------------------

# Seconds to wait for a single MCP tool call to complete.
# Increase for slow or long-running tools. 0 = no timeout.
ToolInvoke__TimeoutSeconds=300

# Maximum number of automatic retry attempts when a tool call fails due to a
# dropped connection.
ToolInvoke__MaxRetryAttempts=2

# ---------------------------------------------------------------------------
# ELICITATION
# ---------------------------------------------------------------------------

# Seconds to wait for a user to respond to an elicitation dialog.
# 0 = wait indefinitely (recommended for interactive use).
Elicitation__TimeoutSeconds=0

# ---------------------------------------------------------------------------
# GATEWAY — docker-compose only
# In single-container mode the gateway talks to localhost:5000 directly.
# ---------------------------------------------------------------------------

# Host port the gateway (frontend) is exposed on.
# Maps to container port 8080.  Access the app at http://localhost:<GATEWAY_PORT>
GATEWAY_PORT=8090

# Override YARP cluster destination so the gateway routes /api/* to the api
# service over the internal Docker network.
# Only needed in docker-compose (multi-container) deployments.
ReverseProxy__Clusters__api-cluster__Destinations__api__Address=http://api:5000/

# ---------------------------------------------------------------------------
# FRONTEND (Vue / Vite) — build-time variables
# These must be set before `npm run build` (or during the Docker image build).
# They are baked into the static JS bundle and cannot be changed at runtime.
# ---------------------------------------------------------------------------

# Base URL the browser uses to reach the API.
# Empty string = same origin (requests go through the gateway — recommended).
# Override only when the API is on a different origin, e.g. http://localhost:5000
VITE_API_BASE_URL=

# App version displayed in the UI footer.
VITE_APP_VERSION=0.5.0
