{
  "AppMetadata": { "Version": "0.5.0" },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LlmService": {
    "OpenAiBaseUrl": "https://api.openai.com/v1",
    "AzureApiVersion": "2024-02-15-preview",
    "MaxRetryAttempts": 3,
    "TimeoutSeconds": 30
  },
  "DevTunnels": {
    "Enabled": true,
    "CapturePort": 5000,
    "Retention": 1000,
    "MaxCaptureBytes": 1048576
  },
  "ToolInvoke": { "TimeoutSeconds": 300, "MaxRetryAttempts": 2 },
  "Elicitation": { "TimeoutSeconds": 0 },
  "AllowedHosts": "*"
}
